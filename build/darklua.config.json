{
    "bundle": {
        "require_mode": "path"
    },
    "generator": {
		"name": "readable"
	},
	"rules": [
		"remove_comments",
		"remove_empty_do",
		"remove_function_call_parens",
		"remove_nil_declaration",
		"remove_types",
		"remove_unused_if_branch",
		"remove_unused_variable",
		"remove_unused_while"
	]
}